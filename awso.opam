depends: [
  "dune" {>= "3.0"}
  "awso-codegen"
  "base64" {>= "3.1.0"}
  "cohttp" {>= "0.21.0"}
  "core"
  "core_unix"
  "cryptokit"
  "ppx_expect"
  "ppx_jane"
  "re" {>= "1.7.2"}
  "xmlm"
  "zarith"
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
